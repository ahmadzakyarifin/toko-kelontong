# ======================================================
# KONFIGURASI APLIKASI KASIR TOKO KELONTONG
# Salin file ini menjadi .env lalu isi sesuai server kamu
# ======================================================

# ---- Database MariaDB ----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=kasir_toko

# ---- Session secret (ubah dengan string acak) ----
SESSION_SECRET=ganti-dengan-string-acak-12345

# ---- Port aplikasi ----
PORT=3000

# ---- Akun default yang dibuat saat seed (boleh diubah) ----
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin123
SEED_KASIR_USERNAME=kasir
SEED_KASIR_PASSWORD=kasir123
