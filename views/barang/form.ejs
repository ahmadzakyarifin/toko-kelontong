<%- include('/partials/navbar.ejs') %>
<main class="max-w-lg mx-auto px-4 py-6">
  <h1 class="text-lg font-bold text-slate-800 mb-4"><%= title %></h1>

  <% if (error) { %>
    <div class="mb-4 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm px-3 py-2"><%= error %></div>
  <% } %>

  <form method="POST" action="<%= action %>" class="bg-white rounded-2xl border border-slate-200 p-5 space-y-3">
    <% if (barang.kode !== undefined) { %>
      <div>
        <label class="block text-sm font-medium text-slate-600 mb-1">Kode</label>
        <input name="kode" value="<%= barang.kode || '' %>" <%= barang.id ? 'readonly' : '' %>
          class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500 font-mono">
      </div>
    <% } %>
    <div>
      <label class="block text-sm font-medium text-slate-600 mb-1">Nama Barang</label>
      <input name="nama" value="<%= barang.nama || '' %>"
        class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
    </div>
    <div class="grid grid-cols-2 gap-3">
      <div>
        <label class="block text-sm font-medium text-slate-600 mb-1">Harga (Rp)</label>
        <input name="harga" type="number" min="0" step="0.01" value="<%= barang.harga != null ? barang.harga : '' %>"
          class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-600 mb-1">Stok</label>
        <input name="stok" type="number" min="0" value="<%= barang.stok != null ? barang.stok : 0 %>"
          class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
      </div>
    </div>
    <div class="grid grid-cols-2 gap-3">
      <div>
        <label class="block text-sm font-medium text-slate-600 mb-1">Satuan</label>
        <input name="satuan" value="<%= barang.satuan || 'pcs' %>"
          class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-600 mb-1">Stok Minimum</label>
        <input name="stok_minimum" type="number" min="0" value="<%= barang.stok_minimum != null ? barang.stok_minimum : 5 %>"
          class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
      </div>
    </div>
    <div class="flex gap-2 pt-2">
      <button class="flex-1 bg-brand-600 hover:bg-brand-700 text-white font-semibold rounded-lg py-2">Simpan</button>
      <a href="/barang" class="px-4 py-2 rounded-lg border border-slate-300 text-slate-600 hover:bg-slate-50">Batal</a>
    </div>
  </form>
</main>
</body>
</html>
