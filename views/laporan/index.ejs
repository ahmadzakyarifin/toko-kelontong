<%- include('/partials/navbar.ejs') %>
<main class="max-w-6xl mx-auto px-4 py-6">
  <h1 class="text-lg font-bold text-slate-800 mb-4">📊 Laporan Penjualan</h1>

  <div class="grid grid-cols-2 gap-4 mb-6">
    <div class="bg-brand-600 text-white rounded-2xl p-5">
      <div class="text-sm opacity-90">Pendapatan Hari Ini</div>
      <div class="text-2xl font-bold mt-1"><%= formatRupiah(ringkasan.total_pendapatan) %></div>
    </div>
    <div class="bg-white border border-slate-200 rounded-2xl p-5">
      <div class="text-sm text-slate-500">Transaksi Hari Ini</div>
      <div class="text-2xl font-bold mt-1 text-slate-800"><%= ringkasan.jumlah_transaksi %></div>
    </div>
  </div>

  <div class="bg-white rounded-2xl border border-slate-200 p-5 mb-6">
    <div class="font-semibold text-slate-700 mb-2">Grafik Pendapatan (14 hari terakhir)</div>
    <% if (harian.length === 0) { %>
      <div class="text-sm text-slate-400">Belum ada transaksi.</div>
    <% } else { %>
      <div class="space-y-1">
        <% harian.slice().reverse().forEach(h => { %>
          <% const max = Math.max(...harian.map(x => Number(x.total_pendapatan))); %>
          <% const pct = max ? (Number(h.total_pendapatan)/max*100) : 0; %>
          <div class="flex items-center gap-2 text-xs">
            <span class="w-20 text-slate-500"><%= new Date(h.tanggal).toLocaleDateString('id-ID',{day:'2-digit',month:'short'}) %></span>
            <div class="flex-1 bg-slate-100 rounded h-4 overflow-hidden">
              <div class="bg-brand-500 h-4" style="width:<%= pct %>%"></div>
            </div>
            <span class="w-28 text-right text-slate-700"><%= formatRupiah(h.total_pendapatan) %></span>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <a href="/laporan/transaksi" class="inline-block bg-slate-700 hover:bg-slate-800 text-white text-sm px-3 py-2 rounded-lg">Lihat Daftar Transaksi</a>
</main>
</body>
</html>
