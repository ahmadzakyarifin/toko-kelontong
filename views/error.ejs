<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Kasir Toko Kelontong</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: { 50:'#f0fdf4',100:'#dcfce7',500:'#22c55e',600:'#16a34a',700:'#15803d' }
          }
        }
      }
    }
  </script>
</head>
<body class="bg-slate-50 text-slate-800 min-h-screen flex items-center justify-center px-4 text-center">
  <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8 max-w-md">
    <div class="text-4xl mb-3">⚠️</div>
    <h1 class="text-lg font-bold text-slate-800"><%= title %></h1>
    <p class="text-sm text-slate-500 mt-2"><%= message %></p>
    <a href="/" class="inline-block mt-5 text-brand-600 font-medium hover:underline">Kembali</a>
  </div>
</body>
</html>
