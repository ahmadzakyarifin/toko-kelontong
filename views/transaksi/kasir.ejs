<%- include('/partials/navbar.ejs') %>
<main class="max-w-6xl mx-auto px-4 py-6">
  <h1 class="text-lg font-bold text-slate-800 mb-4">🧾 Transaksi Penjualan</h1>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    <!-- Daftar barang -->
    <div class="lg:col-span-2 bg-white rounded-2xl border border-slate-200 p-4">
      <input id="searchBarang" placeholder="Cari barang..." oninput="filterBarang()"
        class="w-full rounded-lg border border-slate-300 px-3 py-2 mb-3 focus:outline-none focus:ring-2 focus:ring-brand-500">
      <div id="listBarang" class="grid grid-cols-2 sm:grid-cols-3 gap-2 max-h-[60vh] overflow-auto">
        <% barangs.forEach(b => { %>
          <button type="button" onclick='tambah(<%- JSON.stringify({id:b.id, kode:b.kode, nama:b.nama, harga:Number(b.harga), stok:b.stok, satuan:b.satuan}) %>)'
            class="text-left bg-slate-50 hover:bg-brand-50 border border-slate-200 rounded-xl p-3 transition">
            <div class="text-sm font-medium text-slate-800 truncate"><%= b.nama %></div>
            <div class="text-xs text-brand-700 font-semibold"><%= formatRupiah(b.harga) %></div>
            <div class="text-xs text-slate-400">stok <%= b.stok %> <%= b.satuan %></div>
          </button>
        <% }) %>
      </div>
    </div>

    <!-- Keranjang -->
    <div class="bg-white rounded-2xl border border-slate-200 p-4">
      <div class="font-semibold text-slate-800 mb-2">Keranjang</div>
      <div id="cart" class="space-y-2 max-h-[40vh] overflow-auto mb-3">
        <div id="cartEmpty" class="text-sm text-slate-400 text-center py-6">Belum ada item</div>
      </div>
      <div class="border-t border-slate-100 pt-3">
        <div class="flex justify-between text-sm text-slate-500"><span>Total</span><span id="totalTxt" class="font-bold text-slate-800">Rp 0</span></div>
        <input id="bayar" type="number" min="0" placeholder="Uang Bayar"
          class="w-full mt-2 rounded-lg border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
        <div class="flex justify-between text-sm text-slate-500 mt-2"><span>Kembalian</span><span id="kembalianTxt" class="font-semibold text-brand-700">Rp 0</span></div>
      </div>

      <form id="formCheckout" method="POST" action="/transaksi/checkout" class="mt-3">
        <input type="hidden" name="items" id="itemsInput">
        <input type="hidden" name="bayar" id="bayarInput">
        <button type="button" onclick="bayar()" id="btnBayar"
          class="w-full bg-brand-600 hover:bg-brand-700 text-white font-semibold rounded-lg py-2 disabled:opacity-50" disabled>
          Bayar & Cetak Struk
        </button>
      </form>
    </div>
  </div>
</main>

<script>
  let cart = [];
  const fmt = n => 'Rp ' + Number(n).toLocaleString('id-ID');

  function filterBarang() {
    const q = document.getElementById('searchBarang').value.toLowerCase();
    document.querySelectorAll('#listBarang button').forEach(btn => {
      const t = btn.innerText.toLowerCase();
      btn.style.display = t.includes(q) ? '' : 'none';
    });
  }

  function tambah(p) {
    const exist = cart.find(c => c.id === p.id);
    if (exist) {
      if (exist.qty + 1 > p.stok) { alert('Stok ' + p.nama + ' tidak cukup'); return; }
      exist.qty++;
    } else {
      if (p.stok <= 0) { alert('Stok ' + p.nama + ' habis'); return; }
      cart.push({ ...p, qty: 1 });
    }
    render();
  }

  function ubahQty(id, delta) {
    const c = cart.find(x => x.id === id);
    if (!c) return;
    const baru = c.qty + delta;
    // Validasi: tidak boleh kurang dari 1 dan tidak boleh melebihi stok
    if (baru < 1) return;
    if (baru > c.stok) {
      alert('Stok ' + c.nama + ' tidak cukup (tersisa ' + c.stok + ')');
      return;
    }
    c.qty = baru;
    render();
  }

  function hapus(id) {
    cart = cart.filter(x => x.id !== id);
    render();
  }

  function render() {
    const box = document.getElementById('cart');
    const empty = document.getElementById('cartEmpty');
    box.querySelectorAll('.item').forEach(e => e.remove());
    if (cart.length === 0) { empty.style.display = ''; } else { empty.style.display = 'none'; }

    let total = 0;
    cart.forEach(c => {
      const sub = c.harga * c.qty; total += sub;
      const el = document.createElement('div');
      el.className = 'item flex items-center justify-between bg-slate-50 rounded-lg px-3 py-2';
      el.innerHTML = `<div class="text-sm">
          <div class="font-medium text-slate-700">${c.nama}</div>
          <div class="text-xs text-slate-400">${fmt(c.harga)} x ${c.qty}</div>
        </div>
        <div class="flex items-center gap-1">
          <button type="button" onclick="ubahQty(${c.id},-1)" class="w-6 h-6 rounded bg-slate-200">-</button>
          <span class="text-sm w-6 text-center">${c.qty}</span>
          <button type="button" onclick="ubahQty(${c.id},1)" class="w-6 h-6 rounded bg-slate-200">+</button>
          <span class="text-sm font-semibold text-slate-700 w-20 text-right">${fmt(sub)}</span>
          <button type="button" onclick="hapus(${c.id})" class="text-red-500 text-xs ml-1">x</button>
        </div>`;
      box.appendChild(el);
    });

    document.getElementById('totalTxt').innerText = fmt(total);
    updateKembalian();
  }

  function updateKembalian() {
    const total = cart.reduce((s, c) => s + c.harga * c.qty, 0);
    const bayar = Number(document.getElementById('bayar').value || 0);
    const kembali = Math.max(0, bayar - total);
    document.getElementById('kembalianTxt').innerText = fmt(kembali);
    document.getElementById('btnBayar').disabled = !(cart.length > 0 && bayar >= total);
  }

  function bayar() {
    const total = cart.reduce((s, c) => s + c.harga * c.qty, 0);
    const bayar = Number(document.getElementById('bayar').value || 0);
    if (cart.length === 0) { alert('Keranjang kosong'); return; }
    if (bayar < total) { alert('Uang bayar kurang'); return; }
    document.getElementById('itemsInput').value = JSON.stringify(cart.map(c => ({ barang_id: c.id, qty: c.qty })));
    document.getElementById('bayarInput').value = bayar;
    document.getElementById('formCheckout').submit();
  }

  document.getElementById('bayar').addEventListener('input', updateKembalian);
  render();
</script>
</body>
</html>
